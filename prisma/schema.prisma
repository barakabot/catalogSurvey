// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ProductGroup {
  id        String        @id @default(cuid())
  name      String
  parentId  String?       // null = main group, has value = subgroup
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    ProductGroup? @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProductGroup[] @relation("GroupHierarchy")
  products  Product[]
}

model Product {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  price               Float
  imageUrl            String?
  groupId             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  group               ProductGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  competitorProducts  CompetitorProduct[]
}

model CompetitorProduct {
  id               String                  @id @default(cuid())
  source           String                  // DIGIKALA or SNAPPSHOP
  sourceId         String                  // Product ID from the source platform
  name             String
  imageUrl         String?
  weight           String?                 // وزن
  volume           String?                 // حجم
  price            Float                   // Current price (in Rial for Iranian sites)
  originalPrice    Float?                  // Price before discount
  discountPercent  Float                   @default(0)
  brand            String?                 // Brand name
  fetchedAt        DateTime                @default(now()) // Date of last price fetch
  catalogProductId String?                 // Link to catalog product
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  catalogProduct   Product?               @relation(fields: [catalogProductId], references: [id], onDelete: SetNull)
  priceHistory     CompetitorPriceHistory[]
}

model CompetitorPriceHistory {
  id                  String             @id @default(cuid())
  competitorProductId String
  price               Float
  originalPrice       Float?
  discountPercent     Float              @default(0)
  fetchedAt           DateTime           @default(now())
  competitorProduct   CompetitorProduct  @relation(fields: [competitorProductId], references: [id], onDelete: Cascade)
}

model Settings {
  id       String @id @default("default")
  currencyUnit  String @default("تومان")
  adminPassword String @default("admin123")
}
